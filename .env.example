# Required Environment Variables
# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Environment Configuration
ENVIRONMENT=development|production

# Rate Limiting
MAX_REQUESTS_PER_DAY=1000

# Function Configuration
FUNCTION_DEBUG=true|false
EXTRACTION_TIMEOUT=30000

# Security (Production Only)
JWT_VERIFICATION=true|false
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Analytics and Monitoring (Optional)
VERCEL_ANALYTICS=true|false


# Google Cloud Storage Configuration
GCS_BUCKET_NAME=your-gcs-bucket-name # <--- Make sure this line exists and has the correct bucket name
GCS_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
GCS_PROJECT_ID=your-gcp-project-id  # Not used, added for reference
