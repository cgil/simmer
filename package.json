{
    "name": "simmer",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "supabase:start": "supabase start",
        "supabase:stop": "supabase stop",
        "supabase:status": "supabase status",
        "db:reset": "supabase db reset",
        "db:migration:new": "supabase migration new",
        "functions:serve": "supabase functions serve --env-file .env.local --no-verify-jwt",
        "functions:deploy:dev": "supabase functions deploy recipe-extraction recipe-ideas-generation recipe-creation --project-ref aedgycrrgaxtkennfvma --no-verify-jwt",
        "functions:deploy:prod": "supabase functions deploy recipe-extraction recipe-ideas-generation recipe-creation --project-ref aedgycrrgaxtkennfvma",
        "dev:all": "concurrently \"npm run dev\" \"npm run functions:serve\"",
        "test:function": "curl -i --request POST 'http://localhost:54321/functions/v1/recipe-extraction' --header 'Content-Type: application/json' --data '{\"url\": \"https://www.allrecipes.com/recipe/158968/spinach-and-feta-turkey-burgers/\"}'",
        "test:ideas": "curl -i --request POST 'http://localhost:54321/functions/v1/recipe-ideas-generation' --header 'Content-Type: application/json' --data '{\"prompt\": \"A quick weeknight dinner with chicken and vegetables\"}'",
        "test:creation": "curl -i --request POST 'http://localhost:54321/functions/v1/recipe-creation' --header 'Content-Type: application/json' --data '{\"recipeIdea\": {\"id\": \"chicken-stir-fry\", \"title\": \"Quick Chicken Stir-Fry\", \"description\": \"A flavorful and easy weeknight dinner with tender chicken, colorful vegetables, and a savory sauce.\"}, \"originalPrompt\": \"A healthy stir-fry recipe for weeknight dinners\"}'",
        "deploy": "npm run build && vercel --prod"
    },
    "dependencies": {
        "@emoji-mart/data": "^1.2.1",
        "@emoji-mart/react": "^1.1.1",
        "@emotion/react": "^11.11.3",
        "@emotion/styled": "^11.11.0",
        "@mui/icons-material": "^6.4.1",
        "@mui/material": "^6.4.1",
        "@supabase/supabase-js": "^2.48.1",
        "@types/react-router-dom": "^5.3.3",
        "@vercel/speed-insights": "^1.1.0",
        "emoji-mart": "^5.6.0",
        "react": "^18.3.1",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "^18.3.1",
        "react-mentions": "^4.4.10",
        "react-router-dom": "^6.22.0",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@types/react-mentions": "^4.4.1",
        "@types/uuid": "^10.0.0",
        "@vercel/edge": "^1.2.1",
        "@vitejs/plugin-react": "^4.3.4",
        "concurrently": "^8.2.2",
        "eslint": "^9.17.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-react-refresh": "^0.4.16",
        "globals": "^15.14.0",
        "typescript": "~5.6.2",
        "typescript-eslint": "^8.18.2",
        "vite": "^6.0.5"
    }
}
